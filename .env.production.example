APP_NAME=AI Commerce OS
DATABASE_URL=sqlite:///data/products.db
LOG_FILE=logs/app.log

# 线上默认使用无头浏览器，适合 Docker/VPS 后台运行。
CRAWLER_SEARCH_URL=https://s.1688.com/selloffer/offer_search.htm
CRAWLER_MAX_PRODUCTS=30
CRAWLER_TIMEOUT_MS=120000
CRAWLER_HEADLESS=true
CRAWLER_MANUAL_MODE=false
CRAWLER_MANUAL_WAIT_MS=60000
CRAWLER_USER_DATA_DIR=data/playwright_profile
CRAWLER_CDP_URL=
CRAWLER_AUTO_START_CDP=false
CRAWLER_CDP_PORT=9223
CRAWLER_CDP_USER_DATA_DIR=data/chrome_debug_profile
CRAWLER_CDP_BACKGROUND=true

# 真实上线默认不使用演示数据补齐。
AI_SELECTION_DEMO_FALLBACK=false

# 服务器开启远程 Worker 模式后，不再直接访问 1688，由本地电脑采集回传。
REMOTE_WORKER_ENABLED=true
WORKER_TOKEN=change-me-to-a-long-random-string

# Caddy 反向代理域名；没有域名时使用 :80。
DOMAIN=:80
